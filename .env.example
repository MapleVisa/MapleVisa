# Copy this file to ".env" and fill in real values. Never commit ".env".

# ---- Database: TiDB Cloud Serverless (MySQL-compatible) ---------------------
# TiDB Cloud console -> Connect -> "Connect With: Prisma" gives you this string.
DATABASE_URL="mysql://USER:PASSWORD@gateway01.REGION.prod.aws.tidbcloud.com:4000/maplevisa?sslaccept=strict"

# ---- Auth -------------------------------------------------------------------
# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- AI (OpenAI-compatible provider) ----------------------------------------
AI_PROVIDER="openai"
AI_BASE_URL="https://api.mistral.ai/v1"
AI_API_KEY="your-mistral-api-key"
AI_MODEL="mistral-small-latest"
# Vision model for inspecting uploaded documents (images/PDFs).
AI_VISION_MODEL="pixtral-12b-latest"

# ---- File uploads -----------------------------------------------------------
# In production, uploads go to Vercel Blob when BLOB_READ_WRITE_TOKEN is set
# (Vercel sets it automatically once you connect a Blob store to the project).
# Locally, leave it unset and uploads use the ./uploads folder on disk.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="10"
