# Copy this file to ".env" and fill in real values. Never commit ".env".

# ---- Database: Supabase (PostgreSQL) ----------------------------------------
# Supabase -> Connect -> "ORMs" / Prisma tab gives you BOTH strings below.
# DATABASE_URL = transaction pooler (port 6543) used by the running app.
# DIRECT_URL   = direct connection (port 5432) used for migrations/db push.
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- Transactional email: Resend --------------------------------------------
# Used to send email-verification and password-reset links.
#   1. Create a Resend account, verify a sending domain (or use the test domain).
#   2. Create an API key.
# EMAIL_FROM must be on a domain you've verified in Resend (or onboarding@resend.dev
# for testing, which can only deliver to your own Resend account email).
RESEND_API_KEY="re_..."
EMAIL_FROM="Maple Visa <noreply@yourdomain.com>"
# Absolute site URL used to build links in emails (no trailing slash).
APP_URL="https://maple-visa.vercel.app"

# ---- Auth -------------------------------------------------------------------
# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- AI (OpenAI-compatible provider) ----------------------------------------
AI_PROVIDER="openai"
AI_BASE_URL="https://api.mistral.ai/v1"
AI_API_KEY="your-mistral-api-key"
AI_MODEL="mistral-small-latest"
# Vision model for inspecting uploaded documents (images/PDFs).
AI_VISION_MODEL="pixtral-12b-latest"

# ---- File uploads -----------------------------------------------------------
# Backend priority: S3-compatible (private) -> Vercel Blob -> local disk.
# Documents stream only through the auth-checked /api/documents/[id] route, so
# the bucket stays PRIVATE — there are no public file URLs.
#
# Works with ANY S3-compatible provider. Free, no-credit-card option = Supabase
# Storage. Just swap these env vars to move to R2/Backblaze/S3 later — no code change.
#
# Supabase Storage (free tier, PRIVATE bucket):
#   Supabase -> Project Settings -> Storage -> S3 connection: copy endpoint + region;
#   create S3 access keys there too. Create a PRIVATE bucket named below.
# S3_ENDPOINT="https://YOUR_REF.supabase.co/storage/v1/s3"
# S3_REGION="us-east-1"            # your Supabase project region
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_BUCKET="maplevisa-documents"
#
# Cloudflare R2 shorthand (auto-builds the endpoint), for later:
# R2_ACCOUNT_ID="..."
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
# R2_BUCKET="maplevisa-documents"
#
# Legacy Vercel Blob (public URLs — not recommended for sensitive docs):
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
#
# Local disk fallback for `npm run dev` when nothing above is set:
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="10"

# ---- Rate limiting (optional, recommended in production) ---------------------
# Create a free Upstash Redis database and paste its REST URL + token here so
# login/signup/AI rate limits are enforced across all serverless instances.
# Without these, limiting falls back to per-instance in-memory counters.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxxxxx"
