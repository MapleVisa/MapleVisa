generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for the running app.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used for migrations / `prisma db push`.
  directUrl = env("DIRECT_URL")
}

// APPLICANT | ADMIN | LAWYER
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  fullName     String
  phone        String?
  address      String?
  avatarKey    String? // storage key of the profile image (served via /api/avatar/[id])
  role         String        @default("APPLICANT")
  createdAt    DateTime      @default(now())
  applications Application[] @relation("OwnerApplications")
  lawyerCases  Application[] @relation("LawyerCases")
  conversations Conversation[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

// status: DRAFT | SUBMITTED | UNDER_REVIEW | NEEDS_INFO | VALIDATED | WITH_LAWYER | IN_PROCESSING | APPROVED | REJECTED
model Application {
  id          String   @id @default(cuid())
  reference   String   @unique
  userId      String
  user        User     @relation("OwnerApplications", fields: [userId], references: [id], onDelete: Cascade)
  program     String // EE | PNP | SPONSOR | BUSINESS
  status      String   @default("DRAFT")
  data        String   @db.Text // JSON blob of all field values (set on create)
  currentStep Int      @default(0)
  reviewNote  String?  @db.Text
  lawyerId    String?
  lawyer      User?    @relation("LawyerCases", fields: [lawyerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submittedAt DateTime?

  events        ApplicationEvent[]
  documents     Document[]
  conversations Conversation[]
  messages      Message[]

  @@index([userId])
  @@index([status])
}

// In-app message center. A message either targets a specific user (toUserId set —
// e.g. staff → applicant) or the staff/team inbox (toUserId null — e.g. applicant
// → staff). Optionally tied to an application for context.
model Message {
  id            String       @id @default(cuid())
  fromUserId    String
  fromUser      User         @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId      String?
  toUser        User?        @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  subject       String?
  body          String       @db.Text
  readAt        DateTime?
  createdAt     DateTime     @default(now())

  @@index([toUserId])
  @@index([fromUserId])
  @@index([applicationId])
}

// Saved AI chat threads so users can recall them later.
// kind: "copilot" (applicant, per application + section) | "advisor"
// (applicant, general eligibility) | "case" (staff case summary).
model Conversation {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          String
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  sectionId     String?
  title         String       @default("New conversation")
  messages      String       @db.Text // JSON: [{ role, content, at }] (set on create)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([applicationId])
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploadedById  String
  category      String // e.g. Passport, ECA report, Language results…
  originalName  String  @db.VarChar(255)
  storedName    String // filename on disk
  mimeType      String
  size          Int

  // AI document check
  aiStatus String  @default("NONE") // NONE | CHECKING | DONE | ERROR
  aiVerdict String? // ok | attention | reject
  aiResult  String? @db.Text // JSON blob of the full AI analysis

  // Staff review
  reviewStatus String  @default("PENDING") // PENDING | ACCEPTED | REJECTED
  reviewNote   String? @db.Text
  reviewedBy   String?

  createdAt DateTime @default(now())

  @@index([applicationId])
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // STATUS | NOTE | SYSTEM
  message       String  @db.Text
  actor         String? // name/email of who triggered it
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}
